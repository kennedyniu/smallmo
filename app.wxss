/* app.wxss - 全局样式和专业主题 */

/* ==================== 主题变量定义 ==================== */

/* 简约现代 - 默认 */
page, .container {
  --primary-color: #1890ff;
  --primary-light: #e6f7ff;
  --secondary-color: #52c41a;
  --bg-color: #f5f5f5;
  --card-bg: #ffffff;
  --text-color: #333333;
  --text-color-light: #595959;
  --text-secondary: #666666;
  --border-color: #e8e8e8;
  --divider-color: #f5f5f5;
  --expense-color: #ff4d4f;
  --expense-light: #fff1f0;
  --income-color: #52c41a;
  --income-light: #f6ffed;
  --tab-bg: #ffffff;
  --nav-bg: #ffffff;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.08);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.12);
  --shadow-top: 0 -4rpx 16rpx rgba(0, 0, 0, 0.04);
  /* 语义化文字颜色 */
  --text-on-primary: #ffffff;
  --text-on-secondary: #ffffff;
  --text-on-expense: #ffffff;
  --text-on-income: #ffffff;
  --text-on-card: #333333;
  --text-on-bg: #333333;
  /* 图标颜色 */
  --icon-color: var(--text-secondary);
  --icon-color-active: var(--primary-color);
  /* 动画变量 */
  --transition-speed-fast: 0.15s;
  --transition-speed-normal: 0.2s;
  --transition-speed-slow: 0.3s;
  --transition-timing: ease;
  --transition-timing-bounce: cubic-bezier(0.34, 1.56, 0.64, 1);
}

/* 暗色主题 */
.container[data-theme="dark"], page[data-theme="dark"] {
  --primary-color: #1890ff;
  --primary-light: #1f3a5f;
  --secondary-color: #52c41a;
  --bg-color: #1a1a1a;
  --card-bg: #2a2a2a;
  --text-color: #f5f5f5;
  --text-color-light: #d9d9d9;
  --text-secondary: #999999;
  --border-color: #3a3a3a;
  --divider-color: #262626;
  --expense-color: #ff6b6b;
  --expense-light: #3d1a1a;
  --income-color: #69db7c;
  --income-light: #1a3d20;
  --tab-bg: #2a2a2a;
  --nav-bg: #2a2a2a;
  --shadow-sm: 0 2rpx 8rpx rgba(0, 0, 0, 0.2);
  --shadow-md: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  --shadow-lg: 0 8rpx 24rpx rgba(0, 0, 0, 0.4);
  --shadow-top: 0 -4rpx 16rpx rgba(0, 0, 0, 0.2);
  /* 语义化文字颜色 */
  --text-on-primary: #ffffff;
  --text-on-secondary: #ffffff;
  --text-on-expense: #ffffff;
  --text-on-income: #ffffff;
  --text-on-card: #f5f5f5;
  --text-on-bg: #f5f5f5;
  /* 图标颜色 */
  --icon-color: var(--text-secondary);
  --icon-color-active: var(--primary-color);
}

