  --expense-color: #d32f2f;
  --expense-light: #ffebee;
  --income-color: #388e3c;
  --income-light: #e8f5e9;
  --tab-bg: #ffffff;
  --nav-bg: #1a237e;
  --shadow-sm: 0 2rpx 8rpx rgba(26, 35, 126, 0.08);
  --shadow-md: 0 4rpx 16rpx rgba(26, 35, 126, 0.12);
  --shadow-lg: 0 8rpx 24rpx rgba(26, 35, 126, 0.16);
  --shadow-top: 0 -4rpx 16rpx rgba(26, 35, 126, 0.08);
  /* 语义化文字颜色 */
