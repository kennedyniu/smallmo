/* ==================== 全局样式 ==================== */

page {
  background-color: var(--bg-color);
  color: var(--text-color);
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, 'PingFang SC', 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif;
  line-height: 1.5;
  height: 100%;
  overflow: hidden;
}

.container {
  padding: 24rpx;
  min-height: 100vh;
  background-color: var(--bg-color);
}

/* 卡片样式 */
.card {
  background-color: var(--card-bg);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-color);
}

/* 按钮样式 */
.btn {
  padding: 24rpx 48rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  font-weight: 500;
  text-align: center;
  border: none;
  transition: all 0.2s ease;
}

.btn:active {
  transform: scale(0.98);
  opacity: 0.9;
}

.btn-primary {
  background: linear-gradient(135deg, var(--primary-color), var(--primary-color));
  color: var(--text-on-primary);
  box-shadow: var(--shadow-sm);
}

.btn-secondary {
  background: linear-gradient(135deg, var(--secondary-color), var(--secondary-color));
  color: var(--text-on-secondary);
}

.btn-outline {
  border: 2rpx solid var(--primary-color);
  color: var(--primary-color);
  background-color: transparent;
}

/* 输入框样式 */
.input {
  border: 2rpx solid var(--border-color);
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  background-color: var(--card-bg);
  color: var(--text-color);
  transition: border-color 0.2s ease;
}

.input:focus {
  border-color: var(--primary-color);
}

/* 工具类 */
.flex {
  display: flex;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.text-primary {
  color: var(--primary-color);
}

.text-expense {
  color: var(--expense-color);
}

.text-income {
  color: var(--income-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-light {
  color: var(--text-color-light);
}

.text-bold {
  font-weight: 600;
}

.text-sm {
  font-size: 24rpx;
}

.text-lg {
  font-size: 32rpx;
}

.text-xl {
  font-size: 40rpx;
}

.mt-10 { margin-top: 10rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.mb-10 { margin-bottom: 10rpx; }
.mb-20 { margin-bottom: 20rpx; }
.mb-30 { margin-bottom: 30rpx; }
.p-20 { padding: 20rpx; }
.p-30 { padding: 30rpx; }

/* 金额样式 */
.amount {
  font-weight: 600;
}

.amount-lg {
  font-size: 48rpx;
  font-weight: 700;
}

/* 标签样式 */
.tag {
  display: inline-flex;
  align-items: center;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.tag-primary {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.tag-expense {
  background-color: var(--expense-light);
  color: var(--expense-color);
}

.tag-income {
  background-color: var(--income-light);
  color: var(--income-color);
}

/* 分割线 */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 20rpx 0;
}

/* 阴影 */
.shadow-sm {
  box-shadow: var(--shadow-sm);
}

.shadow-md {
  box-shadow: var(--shadow-md);
}

/* 圆角 */
.radius-sm { border-radius: 8rpx; }
.radius-md { border-radius: 12rpx; }
.radius-lg { border-radius: 20rpx; }
.radius-full { border-radius: 999rpx; }

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 80rpx 40rpx;
}

.empty-state-icon {
  font-size: 96rpx;
  margin-bottom: 24rpx;
  opacity: 0.5;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-secondary);
}