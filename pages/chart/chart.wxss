/* pages/chart/chart.wxss - 图表页面专业样式 */

.container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  box-sizing: border-box;
}

.fixed-header {
  flex-shrink: 0;
  background-color: var(--card-bg);
}

.scroll-content {
  height: calc(100vh - 280rpx);
  min-height: 0;
  padding-bottom: 160rpx;
  box-sizing: border-box;
}

/* 顶部筛选栏 */
.filter-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 24rpx;
  background-color: var(--card-bg);
  margin: -24rpx -24rpx 24rpx;
  position: sticky;
  top: 0;
  z-index: 10;
  box-shadow: var(--shadow-sm);
  border-bottom: 1rpx solid var(--border-color);
}

.filter-left {
  display: flex;
  align-items: center;
}

.account-selector {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--text-color-light);
  max-width: 160rpx;
}

.account-selector text {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.account-selector:active {
  background-color: var(--primary-light);
}

/* 收支页签 */
.type-tabs {
  display: flex;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  padding: 4rpx;
}

.tab-item {
  padding: 12rpx 24rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  border-radius: 8rpx;
  transition: all 0.2s ease;
}

.tab-item.active {
  background-color: var(--primary-color);
  color: var(--text-on-primary);
  font-weight: 600;
}

.date-selector {
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
  font-size: 24rpx;
  color: var(--text-color-light);
}

.date-selector:active {
  background-color: var(--primary-light);
}

.arrow {
  margin-left: 8rpx;
  font-size: 20rpx;
  color: var(--text-secondary);
}

/* 统计信息卡片 */
.summary {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
  background: linear-gradient(135deg, var(--card-bg) 0%, var(--primary-light) 100%);
  border-radius: 24rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-md);
  border: 1rpx solid var(--border-color);
  position: relative;
  overflow: hidden;
}

.summary::before {
  content: '';
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 6rpx;
  background: linear-gradient(90deg, var(--expense-color), var(--income-color));
}

.summary-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  padding: 0 8rpx;
}

.summary-item .label {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-bottom: 8rpx;
  font-weight: 500;
}

.summary-item .amount {
  font-size: 28rpx;
  font-weight: 700;
  letter-spacing: 1rpx;
}

.summary-item .amount.expense {
  color: var(--expense-color);
}

.summary-item .amount.income {
  color: var(--income-color);
}

/* 图表区域 */
.chart-section {
  background-color: var(--card-bg);
  border-radius: 24rpx;
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-sm);
  border: 1rpx solid var(--border-color);
}

.pie-section {
  padding: 16rpx;
}

.chart-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-bottom: 24rpx;
  display: flex;
  align-items: center;
}

.chart-title::before {
  content: '';
  width: 8rpx;
  height: 28rpx;
  background: linear-gradient(180deg, var(--primary-color), var(--secondary-color));
  border-radius: 4rpx;
  margin-right: 12rpx;
}

/* 柱状图样式 */
.bar-scroll {
  width: 100%;
  overflow: hidden;
}

.bar-chart-container {
  height: 160px;
}

.bar-chart {
  display: flex;
  align-items: flex-end;
  height: 140px;
  padding: 0 15px;
  box-sizing: border-box;
}

.bar-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  flex: 1;
  height: 100%;
  justify-content: flex-end;
}

.bar {
  width: 30px;
  border-radius: 4rpx 4rpx 0 0;
  min-height: 4rpx;
}

.bar-amount {
  font-size: 20rpx;
  color: #333;
  margin-bottom: 4rpx;
  white-space: nowrap;
}

.bar-label {
  font-size: 20rpx;
  color: #666;
  margin-top: 4rpx;
}

/* 分类横向条形图样式 */
.category-bar-section {
  padding: 24rpx;
}

.category-bar-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.category-bar-item {
  display: flex;
  flex-direction: column;
}

.category-bar-header {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.category-bar-color {
  width: 16rpx;
  height: 16rpx;
  border-radius: 4rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.category-bar-name {
  flex: 1;
  font-size: 26rpx;
  color: var(--text-color);
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.category-bar-value {
  font-size: 26rpx;
  color: var(--text-color);
  font-weight: 600;
  margin-left: 16rpx;
}

.category-bar-percent {
  font-size: 24rpx;
  color: var(--text-secondary);
  margin-left: 12rpx;
  min-width: 70rpx;
  text-align: right;
}

.category-bar-track {
  height: 16rpx;
  background-color: var(--bg-color);
  border-radius: 8rpx;
  overflow: hidden;
}

.category-bar-fill {
  height: 100%;
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.legend-row:last-child {
  border-bottom: none;
}

.legend-arrow {
  width: 0;
  height: 0;
  border-top: 8rpx solid transparent;
  border-bottom: 8rpx solid transparent;
  border-left: 12rpx solid var(--primary-color);
  margin-right: 8rpx;
}

.legend-row .legend-color {
  width: 18rpx;
  height: 18rpx;
  border-radius: 4rpx;
  margin-right: 6rpx;
  flex-shrink: 0;
}

.legend-row .legend-name {
  flex: 1;
  font-size: 22rpx;
  color: var(--text-color);
}

.legend-row .legend-value {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-right: 12rpx;
}

.legend-row .legend-percent {
  font-size: 20rpx;
  color: var(--text-secondary);
  min-width: 120rpx;
  text-align: right;
}

/* 图例 */
.chart-legend {
  display: flex;
  flex-wrap: wrap;
  margin-top: 24rpx;
  gap: 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  width: calc(50% - 6rpx);
  padding: 16rpx 12rpx;
  background-color: var(--bg-color);
  border-radius: 12rpx;
}

.legend-color {
  width: 24rpx;
  height: 24rpx;
  border-radius: 6rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.legend-name {
  flex: 1;
  font-size: 24rpx;
  color: var(--text-color-light);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.legend-value {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--text-color);
  margin-left: 8rpx;
}

.legend-percent {
  font-size: 22rpx;
  color: var(--text-secondary);
  margin-left: 8rpx;
}

/* 空状态 */
.empty-tip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 40rpx;
}

.empty-tip text {
  font-size: 28rpx;
  color: var(--text-secondary);
}

/* 选择器样式 */
.picker-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 100;
  backdrop-filter: blur(4rpx);
}

.account-picker,
.date-picker {
  position: fixed;
  top: 10vh;
  left: 24rpx;
  right: 24rpx;
  bottom: 10vh;
  background: var(--card-bg);
  border-radius: 24rpx;
  z-index: 101;
  overflow-y: auto;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: scale(0.9);
  }
  to {
    opacity: 1;
    transform: scale(1);
  }
}

.picker-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--border-color);
  font-size: 32rpx;
  font-weight: 600;
  position: sticky;
  top: 0;
  background: var(--card-bg);
  z-index: 1;
}

.close {
  font-size: 44rpx;
  color: var(--text-secondary);
  padding: 8rpx;
  line-height: 1;
}

.confirm-btn {
  color: var(--primary-color);
  font-size: 30rpx;
  font-weight: 600;
  padding: 8rpx 16rpx;
}

.picker-list {
  padding: 16rpx 24rpx;
  padding-bottom: calc(24rpx + env(safe-area-inset-bottom));
  max-height: 75vh;
  overflow-y: auto;
}

.picker-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 32rpx 16rpx;
  border-bottom: 1rpx solid var(--divider-color);
  font-size: 30rpx;
  color: var(--text-color);
  transition: background-color 0.2s ease;
}

.picker-item:active {
  background-color: var(--bg-color);
}

.picker-item:last-child {
  border-bottom: none;
}

.picker-item.active {
  background-color: var(--primary-light);
  color: var(--primary-color);
}

.picker-item.active .check {
  color: var(--primary-color);
}

.check {
  color: var(--primary-color);
  font-weight: 700;
  font-size: 32rpx;
}

/* 日期选择器2列布局 */
.date-picker-content {
  display: flex;
  height: 400rpx;
}

.picker-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  border-right: 1rpx solid var(--border-color);
}

.picker-column:last-child {
  border-right: none;
}

.column-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--text-color);
  text-align: center;
  padding: 24rpx 0;
  border-bottom: 1rpx solid var(--border-color);
  background-color: var(--bg-color);
}

.picker-scroll {
  flex: 1;
}

.date-picker-content .picker-item {
  padding: 28rpx 16rpx;
  text-align: center;
  justify-content: center;
}

.picker-empty {
  text-align: center;
  padding: 40rpx;
  color: var(--text-secondary);
  font-size: 26rpx;
}

/* 复选框样式 */
.checkbox-item {
  display: flex;
  align-items: center;
}

.checkbox {
  width: 40rpx;
  height: 40rpx;
  border: 2rpx solid var(--border-color);
  border-radius: 8rpx;
  margin-right: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background-color: var(--bg-color);
}

.checkbox.checked {
  background-color: var(--primary-color);
  border-color: var(--primary-color);
}

.checkbox text {
  color: var(--text-on-primary);
  font-size: 24rpx;
  font-weight: 700;
}

.picker-text {
  flex: 1;
}